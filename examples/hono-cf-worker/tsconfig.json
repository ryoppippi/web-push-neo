{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext"],
		"module": "Preserve",
		"moduleDetection": "force",
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": true,
		"erasableSyntaxOnly": true,
		"strict": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"skipLibCheck": true,
		"types": ["@cloudflare/workers-types"]
	},
	"include": ["src"]
}
